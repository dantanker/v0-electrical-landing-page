# Canonical site URL for metadata, sitemap, and social previews
NEXT_PUBLIC_SITE_URL=https://voltguard.com

# Optional override for Open Graph image path (default: /og/voltguard-og.png)
# NEXT_PUBLIC_OG_IMAGE_PATH=/og/voltguard-og.png

# Optional — only needed if switching back to Google Maps JavaScript API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
